{
  "_comment": "DIY Scalp Config — fast signals, tight expiry window, best for M1/M5/M15 charts",
  "symbol": "GOLD",
  "timeframe": "M1",
  "alternate_signal": false,
  "strict_htf_trend": false,
  "enable_sideways_mode": true,
  "regime_adx_threshold": 10.0,
  "sideways_settings": {
    "lookback_period": 14,
    "rsi_length": 14,
    "volume_threshold": 2.0,
    "divergence_threshold": 0.05,
    "overbought": 65,
    "oversold": 35
  },

  "leading_indicator": {
    "name": "2 EMA Cross",
    "params": {
      "fast": 9,
      "slow": 21
    }
  },

  "confirmation_filters": [
    {
      "name": "rqk",
      "enabled": false,
      "params": {
        "lookback": 8.0,
        "relative_weight": 8.0,
        "start_bar": 25,
        "lag": 2
      }
    },
    {
      "name": "wae",
      "enabled": false,
      "params": {
        "sensitivity": 150,
        "fast_ema": 20,
        "slow_ema": 40,
        "bb_length": 20,
        "bb_mult": 2.0,
        "deadzone_rma": 100,
        "deadzone_mult": 2.5
      }
    },
    {
      "name": "adx",
      "enabled": false,
      "params": {
        "di_length": 10,
        "adx_length": 5,
        "key_level": 15,
        "mode": "adx_di"
      }
    },
    {
      "name": "rsi",
      "enabled": false,
      "params": {
        "rsi_length": 14,
        "mode": "ma_cross"
      }
    },
    {
      "name": "macd",
      "enabled": false,
      "params": {
        "fast_length": 12,
        "slow_length": 26,
        "signal_length": 9,
        "mode": "crossover"
      }
    },
    {
      "name": "supertrend",
      "enabled": false,
      "params": {
        "period": 10,
        "multiplier": 3.0
      }
    },
    {
      "name": "stochastic",
      "enabled": false,
      "params": {
        "length": 14,
        "smooth_k": 3,
        "smooth_d": 3,
        "mode": "ob_os_crossover"
      }
    },
    {
      "name": "cci",
      "enabled": false,
      "params": {
        "length": 20,
        "upper_band": 100,
        "lower_band": -100
      }
    },
    {
      "name": "ema_filter",
      "enabled": false,
      "params": {
        "period": 200
      }
    }
  ]
}
