# MetaTrader 5 Credentials (XM 360 Global)
MT5_ACCOUNT=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=XMGlobal-Demo3

# Exchange API Keys (Binance / ByBit)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret
BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET=your_bybit_secret
CCXT_TESTNET=true

# ── Bot Settings ──────────────────────────────────────────────
# Options: DEMO | REAL | FUNDED
BOT_MODE=DEMO
# Options: XAUUSD | BTCUSD | BOTH
BOT_ASSETS=BOTH
# Options: SCALP | SWING | AUTO
BOT_STRATEGY=AUTO
# Risk per trade in % (0.1–5.0)
BOT_RISK_PCT=1.0

# ── Funded / Prop Firm ────────────────────────────────────────
# Options: FTMO | MyForexFunds | The5ers | Apex | TrueForex | CUSTOM
FUNDED_FIRM=FTMO
# Options: PHASE_1_CHALLENGE | PHASE_2_VERIFICATION | LIVE_FUNDED
FUNDED_PHASE=PHASE_1_CHALLENGE
FUNDED_BALANCE=10000

# ── Supabase (Free PostgreSQL) ────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── Firebase Auth ─────────────────────────────────────────────
# Paste your Firebase service account JSON as a single line
FIREBASE_CONFIG_JSON={"type":"service_account","project_id":"your-project",...}

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_starter_id_from_stripe
STRIPE_PRICE_PRO=price_pro_id_from_stripe
STRIPE_PRICE_ELITE=price_elite_id_from_stripe

# ── News & Sentiment ──────────────────────────────────────────
NEWS_API_KEY=your_newsapi_org_key

# ── Telegram Alerts ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Email Alerts (Gmail SMTP) ─────────────────────────────────
GMAIL_USER=signals@agniv.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── Frontend & Admin ──────────────────────────────────────────
FRONTEND_URL=https://agniv.vercel.app
# Comma-separated Firebase UIDs of admins
ADMIN_UIDS=firebase_uid_of_admin1,firebase_uid_of_admin2
